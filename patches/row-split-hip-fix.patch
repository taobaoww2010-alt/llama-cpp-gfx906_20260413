diff --git a/ggml/src/ggml-cuda/ggml-cuda.cu b/ggml/src/ggml-cuda/ggml-cuda.cu
index 1234567..abcdefg 100644
--- a/ggml/src/ggml-cuda/ggml-cuda.cu
+++ b/ggml/src/ggml-cuda/ggml-cuda.cu
@@ -1482,17 +1482,33 @@ static cudaError_t ggml_cuda_Memcpy2DPeerAsync(
     void * dst, int dstDevice, size_t dpitch, void * src, int srcDevice, size_t spitch, size_t width, size_t height, cudaStream_t stream) {
 
 #if !defined(GGML_USE_HIP) && !defined(GGML_USE_MUSA)
     // cudaMemcpy2DAsync may fail with copies between vmm pools of different devices
     cudaMemcpy3DPeerParms p = {};
     p.dstDevice = dstDevice;
     p.dstPtr = make_cudaPitchedPtr(dst, dpitch, dpitch, height);
     p.srcDevice = srcDevice;
     p.srcPtr = make_cudaPitchedPtr(src, spitch, spitch, height);
     p.extent = make_cudaExtent(width, height, 1);
     return cudaMemcpy3DPeerAsync(&p, stream);
 #elif defined(GGML_USE_HIP)
-    // HIP does not support cudaMemcpy3DPeerAsync or vmm pools
-    GGML_UNUSED(dstDevice);
-    GGML_UNUSED(srcDevice);
-    return cudaMemcpy2DAsync(dst, dpitch, src, spitch, width, height, cudaMemcpyDeviceToDevice, stream);
+    // HIP does not support cudaMemcpy3DPeerAsync
+    // Use hipMemcpyPeerAsync in a loop to handle 2D copies correctly
+    // This is needed because hipMemcpy2DAsync may not work correctly for cross-GPU copies on gfx906
+    char * dst_ptr = (char *)dst;
+    const char * src_ptr = (const char *)src;
+    for (size_t row = 0; row < height; ++row) {
+        cudaError_t err = cudaMemcpyPeerAsync(dst_ptr + row * dpitch, dstDevice,
+                                               src_ptr + row * spitch, srcDevice,
+                                               width, stream);
+        if (err != cudaSuccess) {
+            return err;
+        }
+    }
+    return cudaSuccess;
 #else
-    // HIP does not support cudaMemcpy3DPeerAsync or vmm pools
+    // MUSA - fallback to cudaMemcpy2DAsync
     GGML_UNUSED(dstDevice);
     GGML_UNUSED(srcDevice);
     return cudaMemcpy2DAsync(dst, dpitch, src, spitch, width, height, cudaMemcpyDeviceToDevice, stream);
-#endif // !defined(GGML_USE_HIP) && !defined(GGML_USE_MUSA)
+#endif
 }
